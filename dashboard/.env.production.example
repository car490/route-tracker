# Dashboard client env (public, embedded at build time)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
VITE_OS_PLACES_API_KEY=your_os_places_key
VITE_ORS_API_KEY=your_openrouteservice_key

# Server-side env (for Vercel functions / API routes)
GRAPHHOPPER_URL=https://graphhopper.example.com
GRAPHHOPPER_PROFILE=pcv
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=ops@example.com

# Optional aliases currently supported by API code
# GH_URL=https://graphhopper.example.com
# GH_PROFILE=pcv
# GRAPHHOPPER_API_URL=https://graphhopper.example.com
